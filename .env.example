# Elasticsearch
ES_USERNAME=elastic
ES_PASSWORD=your_elasticsearch_password_here
ES_CA_CERT=./elasticsearch-8.8.0/config/certs/http_ca.crt

# OpenAI (RAGAS 평가에 사용 — GOOGLE_API_KEY와 택일)
OPENAI_API_KEY=your_openai_api_key_here

# Google AI Studio (RAGAS 평가에 사용 — OPENAI_API_KEY보다 우선)
GOOGLE_API_KEY=your_google_ai_studio_api_key_here
